# ── Required ──────────────────────────────────────────────────────────────

# Supabase Postgres connection string. Use the "Session pooler" URI
# (Settings → Database → Connection string → Session pooler).
DATABASE_URL=

# Password for the single admin login.
ADMIN_PASSWORD=

# Signs/verifies the admin session cookie. Generate: openssl rand -hex 32
SESSION_SECRET=

# ── Photo uploads (Vercel Blob) ───────────────────────────────────────────

# Auto-injected by Vercel when you connect a Blob store. Leave blank locally;
# pull the real value with `vercel env pull .env.local` to enable uploads.
BLOB_READ_WRITE_TOKEN=

# ── Slack digests + cron (optional) ───────────────────────────────────────

# Bearer token guarding the /api/cron/* digest endpoints.
CRON_SECRET=

# Slack incoming-webhook (or workflow trigger) URLs for the digests.
SLACK_WEBHOOK_URL=
SLACK_DAILY_WEBHOOK_URL=
